# ============================================
#  FRONTEND (Next.js) — copy file này thành .env
# ============================================

# --- Local / Dev ---  (FE chạy ở cổng 3001: npm run dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# URL Backend — CHỈ dùng server-side
API_BASE_URL=http://localhost:3000

# API key của user "service" bên Backend — server-side, KHÔNG đặt NEXT_PUBLIC_
API_SERVICE_TOKEN=

# Phải KHỚP với REVALIDATE_SECRET bên Backend
REVALIDATE_SECRET=

# Google Analytics 4 (tùy chọn)
NEXT_PUBLIC_GA_ID=

# ============================================
#  PRODUCTION — bỏ comment & thay khi deploy
# ============================================
# NEXT_PUBLIC_SITE_URL=https://casestudy.mktsoftware.vn
# API_BASE_URL=https://api.casestudy.mktsoftware.vn
